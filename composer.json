{
	"name": "typo3/cms-base-distribution",
	"description": "TYPO3 CMS Base Distribution",
	"license": "GPL-2.0-or-later",
	"type": "project",
	"minimum-stability": "dev",
	"prefer-stable": true,
	"config": {
		"allow-plugins": {
			"a9f/fractor-extension-installer": true,
			"typo3/class-alias-loader": true,
			"typo3/cms-composer-installers": true
		},
		"platform": {
			"php": "8.3.0"
		},
		"sort-packages": true
	},
	"require": {
		"friendsoftypo3/content-blocks": "^1.3",
		"uzbecano/uzbecano-site": "^13.4",
		"longman/telegram-bot": "^0.83.1",
		"typo3/cms-adminpanel": "^13.4",
		"typo3/cms-backend": "^13.4",
		"typo3/cms-belog": "^13.4",
		"typo3/cms-beuser": "^13.4",
		"typo3/cms-core": "^13.4",
		"typo3/cms-dashboard": "^13.4",
		"typo3/cms-extbase": "^13.4",
		"typo3/cms-filelist": "^13.4",
		"typo3/cms-fluid": "^13.4",
		"typo3/cms-fluid-styled-content": "^13.4",
		"typo3/cms-form": "^13.4",
		"typo3/cms-frontend": "^13.4",
		"typo3/cms-info": "^13.4",
		"typo3/cms-install": "^13.4",
		"typo3/cms-lowlevel": "^13.4",
		"typo3/cms-recycler": "^13.4",
		"typo3/cms-redirects": "^13.4",
		"typo3/cms-reports": "^13.4",
		"typo3/cms-rte-ckeditor": "^13.4",
		"typo3/cms-scheduler": "^13.4",
		"typo3/cms-seo": "^13.4",
		"typo3/cms-setup": "^13.4",
		"typo3/cms-sys-note": "^13.4",
		"typo3/cms-tstemplate": "^13.4",
		"typo3/cms-viewpage": "^13.4",
		"typo3/cms-workspaces": "^13.4",
		"uzbecano/telegram-messenger": "^1.0"
	},
	"repositories": {
		"local": {
			"type": "path",
			"url": "./packages/*"
		}
	},
	"scripts": {
		"check:cs": "./vendor/bin/php-cs-fixer fix --dry-run --config ./Build/config/php-cs/.php-cs-fixer.php --using-cache no --show-progress dots -v --diff --format=txt",
		"ci:check:cs": "./vendor/bin/php-cs-fixer fix --dry-run --config ./Build/config/php-cs/.php-cs-fixer.php --using-cache no -vvv --diff --format=checkstyle | cs2pr",
		"fix:cs": "./vendor/bin/php-cs-fixer fix --config ./Build/config/php-cs/.php-cs-fixer.php --using-cache no --show-progress dots -v --diff --format=txt",
		"ci:fix:cs": "./vendor/bin/php-cs-fixer fix --config ./Build/config/php-cs/.php-cs-fixer.php --using-cache no --show-progress dots --diff --format=checkstyle",
		"check:phpstan": "./vendor/bin/phpstan analyse -c ./Build/config/phpstan/phpstan.neon",
		"ci:check:phpstan": "./vendor/bin/phpstan analyse -c ./Build/config/phpstan/phpstan.neon --error-format=github --no-progress",
		"check:typoscript": "./vendor/bin/typoscript-lint -c ./vendor/leuchtfeuer/ci-config/typoscript-lint/config.yaml ./packages/*/Configuration/TypoScript/",
		"ci:check:typoscript": "./vendor/bin/typoscript-lint -f checkstyle -c ./vendor/leuchtfeuer/ci-config/typoscript-lint/config.yaml ./packages/*/Configuration/TypoScript/",
		"check:xliff": "php ./vendor/leuchtfeuer/ci-config/xliff/xliff-lint lint:xliff --format=txt ./packages/*/Resources/Private/Language",
		"ci:check:xliff": "php ./vendor/leuchtfeuer/ci-config/xliff/xliff-lint lint:xliff --format=github ./packages/*/Resources/Private/Language",
		"tests:unit": "./vendor/bin/phpunit -c ./Build/config/phpunit/phpunit.xml --testsuite unit",
		"ci:tests:unit": "./vendor/bin/phpunit -c ./Build/config/phpunit/phpunit.xml --testsuite unit --no-progress --testdox",
		"tests:functional": "./vendor/bin/phpunit -c ./Build/config/phpunit/phpunit.xml --bootstrap vendor/typo3/testing-framework/Resources/Core/Build/FunctionalTestsBootstrap.php --testsuite functional",
		"ci:tests:functional": "./vendor/bin/phpunit -c ./Build/config/phpunit/phpunit.xml --bootstrap vendor/typo3/testing-framework/Resources/Core/Build/FunctionalTestsBootstrap.php --testsuite functional --no-progress --testdox",
		"check": [
			"@check:cs",
			"@check:phpstan",
			"@check:typoscript",
			"@check:xliff"
		],
		"tests": [
			"@tests:unit",
			"@tests:functional"
		]
	}
}
